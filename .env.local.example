# ============================================
# AI API Configuration
# ============================================

# Вариант 1: Z.AI (GLM-4.7-Flash) - основной провайдер
# Получить ключ: https://z.ai/
ZAI_API_KEY=your_zai_api_key_here

# Вариант 2: OpenRouter (резервный/альтернативный провайдер)
# Поддерживает Claude, GPT-4, GLM и другие модели
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# Site Configuration
# ============================================

# URL сайта для заголовка HTTP-Referer (обязательно для OpenRouter)
NEXT_PUBLIC_SITE_URL=https://chatbot24-widget.vercel.app

# ============================================
# Bitrix24 Integration
# ============================================

# Webhook URL для интеграции с Bitrix24
# Настройка: Bitrix24 → Приложения → Вебхуки → Входящий вебхук
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/xxxxxxxxxxxx/

# ID ответственного менеджера для новых лидов
BITRIX24_MANAGER_ID=1

# ============================================
# Redis (Upstash) - для rate limiting и кэширования
# ============================================

# URL и токен из Upstash Console
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ============================================
# Optional: Debug Mode
# ============================================

# Включить расширенное логирование (только для разработки)
# DEBUG_AI=true
