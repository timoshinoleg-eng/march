e:["$","p",null,{"className":"text-gray-400 leading-relaxed mb-4","children":"Мы разработали чат-бота для Telegram и Instagram Direct, который:"}]
f:["$","ul",null,{"className":"list-disc list-inside text-gray-400 space-y-2 mb-6","children":[["$","li",null,{"children":"Мгновенно отвечает на заявки 24/7"}],["$","li",null,{"children":"Задаёт уточняющие вопросы об опыте и целях"}],["$","li",null,{"children":"Проводит первичную квалификацию (бюджет, сроки, уровень)"}],["$","li",null,{"children":"Записывает на бесплатную консультацию в календарь"}],["$","li",null,{"children":"Передаёт горячие лида менеджеру с полной информацией"}]]}]
10:["$","h2",null,{"className":"text-xl sm:text-2xl font-bold text-white mt-8 mb-4","children":"Сценарий работы"}]
11:["$","p",null,{"className":"text-gray-400 leading-relaxed mb-4","children":"Бот приветствует клиента, уточняет его текущий уровень знаний (новичок / есть опыт / профессионал), спрашивает цели обучения и желаемые сроки. Для новичков предлагает бесплатный вебинар, для опытных — созвон с ментором."}]
12:["$","p",null,{"className":"text-gray-400 leading-relaxed mb-4","children":"После квалификации бот предлагает выбрать удобное время для консультации и автоматически создаёт событие в Google Calendar менеджера с пометкой о сегменте клиента."}]
